{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "^startup$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/session-start.sh\"",
            "statusMessage": "Ensuring pre-commit hooks are installed"
          }
        ]
      }
    ]
  }
}
