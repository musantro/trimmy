{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "^(startup|resume)$",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'repo_root=\"$(git rev-parse --show-toplevel)\" && \"$repo_root/.codex/hooks/session-start.sh\"'",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& ([System.IO.Path]::Combine((& git rev-parse --show-toplevel).Trim(), '.codex/hooks/session-start.ps1'))\"",
            "statusMessage": "Ensuring pre-commit hooks are installed"
          }
        ]
      }
    ]
  }
}
